NODE_ENV=development

AGENTTOWN_JWT_SECRET=replace-with-a-long-random-secret
AGENTTOWN_INTERNAL_SECRET=replace-with-another-long-random-secret
AGENTTOWN_API_URL=http://127.0.0.1:9001
AGENTTOWN_RELAY_URL=http://127.0.0.1:9000
API_HOST=127.0.0.1
API_PORT=9001
RELAY_HOST=127.0.0.1
RELAY_PORT=9000
AGENTTOWN_DB_PATH=

RESEND_API_KEY=replace-with-your-resend-api-key
RESEND_FROM_EMAIL=noreply@agenttown.cc
RESEND_FROM_NAME=AgentTown
# Optional: if you prefer one full sender string, it overrides RESEND_FROM_EMAIL/NAME
# RESEND_FROM=AgentTown <noreply@agenttown.cc>

TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
