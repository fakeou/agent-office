{
  "name": "agent-town-monorepo",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "description": "Local-first AI workshop supervisor for Claude, Codex, and other terminal coding agents.",
  "scripts": {
    "postinstall": "node -e \"const { ensureNodePtySpawnHelper } = require('./packages/runtime/src/ensure-node-pty'); const result = ensureNodePtySpawnHelper(); if (result.changed.length) console.log('Repaired node-pty spawn-helper permissions:', result.changed.join(', '));\"",
    "start": "node packages/cli/src/index.js start",
    "app:dev": "pnpm --filter @agent-town/app dev",
    "app:build": "pnpm --filter @agent-town/app build",
    "app:preview": "pnpm --filter @agent-town/app preview",
    "cli:start": "node packages/cli/src/index.js start",
    "cli:codex": "node packages/cli/src/index.js codex",
    "cli:claude": "node packages/cli/src/index.js claude",
    "cleanup": "node packages/cli/src/index.js cleanup",
    "attach": "node packages/cli/src/index.js attach",
    "codex": "node packages/cli/src/index.js codex",
    "claude": "node packages/cli/src/index.js claude",
    "run": "node packages/cli/src/index.js run",
    "print-claude-hooks": "node packages/cli/src/index.js print-claude-hooks",
    "relay": "node services/relay/src/index.js",
    "api": "node services/api/src/index.js"
  },
  "dependencies": {
    "express": "^4.21.2",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0",
    "better-sqlite3": "^11.0.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0"
  }
}
